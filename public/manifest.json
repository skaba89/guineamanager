    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "/icons/screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Tableau de bord GuinéaManager"
    },
    {
      "src": "/icons/screenshot-mobile.png",
      "sizes": "640x1136",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Application mobile GuinéaManager"
    }
  ],
  "shortcuts": [
    {
      "name": "Nouvelle vente",
      "short_name": "Vente",
      "description": "Créer une nouvelle vente rapide",
      "url": "/?page=mobile",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Mobile Money",
      "short_name": "Paiement",
      "description": "Effectuer un paiement Mobile Money",
      "url": "/?page=mobile-money",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Factures",
      "short_name": "Factures",
      "description": "Gérer les factures",
      "url": "/?page=factures",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "file_handlers": [
    {
      "action": "/?action=open",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      }
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["application/json", "text/csv"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+guineamanager",
      "url": "/?action=%s"
    }
  ]
}
