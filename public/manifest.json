{
  "name": "GuinéaManager - ERP pour PME",
  "short_name": "GuinéaManager",
  "description": "Solution ERP complète pour les PME en Afrique de l'Ouest - Gestion commerciale, Mobile Money, RH, Comptabilité OHADA",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#059669",
  "lang": "fr",
  "categories": ["business", "finance", "productivity"],
