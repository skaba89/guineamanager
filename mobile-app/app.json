{
  "expo": {
    "name": "GuinéaManager",
    "slug": "guineamanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "guineamanager",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E40AF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guineamanager.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GuinéaManager a besoin d'accéder à votre appareil photo pour scanner des documents et des codes QR.",
        "NSFaceIDUsageDescription": "GuinéaManager utilise Face ID pour sécuriser votre compte.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "config": {
        "googleSignIn": {
          "reservedClientId": ""
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E40AF"
      },
      "package": "com.guineamanager.app",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "CAMERA",
        "USE_BIOMETRIC"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "GuinéaManager",
      "shortName": "GuinéaManager",
      "description": "ERP Mobile pour PME guinéennes",
      "themeColor": "#1E40AF",
      "backgroundColor": "#FFFFFF",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "icons": [
        {
          "src": "./assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        },
        {
          "src": "./assets/icon-512.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GuinéaManager a besoin d'accéder à votre appareil photo pour scanner des documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "guineamanager-mobile"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/guineamanager-mobile"
    }
  }
}
