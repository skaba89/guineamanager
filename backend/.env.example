# ==============================================================================
# GuinéaManager Backend - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ==============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ============================================================================
# DATABASE (SQLite)
# ============================================================================
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ============================================================================
# AUTHENTICATION
# ============================================================================
# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Expiration (in seconds)
JWT_EXPIRES_IN=604800

# ============================================================================
# REDIS (Optional - for caching and sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@guineamanager.com

# ============================================================================
# SMS CONFIGURATION (Africa's Talking - Optional)
# ============================================================================
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_USERNAME=your-username
AFRICASTALKING_SENDER_ID=GuineaManager

# ============================================================================
# MOBILE MONEY - ORANGE MONEY
# ============================================================================
ORANGE_MONEY_API_KEY=your-orange-api-key
ORANGE_MONEY_API_SECRET=your-orange-api-secret
ORANGE_MONEY_MERCHANT_CODE=your-merchant-code

# ============================================================================
# MOBILE MONEY - MTN
# ============================================================================
MTN_MONEY_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MONEY_API_USER=your-api-user
MTN_MONEY_API_KEY=your-mtn-api-key

# ============================================================================
# MOBILE MONEY - WAVE
# ============================================================================
WAVE_API_KEY=your-wave-api-key
WAVE_API_SECRET=your-wave-api-secret

# ============================================================================
# EXTERNAL APIs
# ============================================================================
# Exchange rates API
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# ============================================================================
# SECURITY
# ============================================================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Password reset token expiration (in hours)
PASSWORD_RESET_EXPIRES=1

# Email verification expiration (in hours)
EMAIL_VERIFICATION_EXPIRES=24

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ============================================================================
# FEATURES FLAGS
# ============================================================================
ENABLE_2FA=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_MOBILE_MONEY=true

# ============================================================================
# PLAN LIMITS
# ============================================================================
PLAN_PETITE_MAX_INVOICES=20
PLAN_MOYENNE_MAX_INVOICES=200
PLAN_GRANDE_MAX_INVOICES=1000
