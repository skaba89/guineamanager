  @@index([webhookId])
  @@index([createdAt])
}

model Partner {
  id              String    @id @default(cuid())
  code            String    @unique
  nom             String
  email           String    @unique
  telephone       String
  adresse         String?
  ville           String?
  pays            String    @default("Guinée")
  type            String    @default("AFFILIATE") // RESELLER, AFFILIATE, INTEGRATOR
  commission      Int       @default(15)
  status          String    @default("EN_ATTENTE")
  logo            String?
  website         String?
  description     String?
  motivation      String?
  clientsCount    Int       @default(0)
  revenueTotal    Int       @default(0)
  commissionTotal Int       @default(0)
  approvedAt      DateTime?
  suspendedAt     DateTime?
  suspensionRaison String?
