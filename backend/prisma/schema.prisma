  lignesBilan          LigneBilan[]
  lignesCompteResultat LigneCompteResultat[]
  soldesComptes        SoldeCompte[]

  @@unique([companyId, annee])
  @@index([companyId])
  @@index([statut])
}

model JournalComptable {
  id                 String              @id @default(cuid())
  companyId          String
  code               String
  nom                String
  type               String
  compteContrepartie String?
  actif              Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ecritures          EcritureComptable[]
  company            Company             @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
}

model EcritureComptable {
  id             String            @id @default(cuid())
  journalId      String
  exerciceId     String
  numeroPiece    String
  dateEcriture   DateTime          @default(now())
  compteNumero   String
  compteIntitule String
  libelle        String
  reference      String?
  debit          Int               @default(0)
  credit         Int               @default(0)
  solde          Int               @default(0)
  lettrage       String?
  dateLettrage   DateTime?
  tiersType      String?
  tiersId        String?
  tiersNom       String?
  sourceType     String?
  sourceId       String?
  valide         Boolean           @default(false)
  validePar      String?
  dateValidation DateTime?
  companyId      String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  exercice       ExerciceComptable @relation(fields: [exerciceId], references: [id])
  journal        JournalComptable  @relation(fields: [journalId], references: [id])

  @@index([journalId])
  @@index([exerciceId])
  @@index([compteNumero])
  @@index([dateEcriture])
  @@index([companyId])
}

model SoldeCompte {
