  updatedAt       DateTime  @updatedAt
  clients         PartnerClient[]
  commissions     PartnerCommission[]

  @@index([code])
  @@index([email])
  @@index([status])
  @@index([type])
}

model PartnerClient {
  id          String    @id @default(cuid())
  partnerId   String
  companyId   String
  commission  Int       @default(15)
  revenue     Int       @default(0)
  createdAt   DateTime  @default(now())
  partner     Partner   @relation(fields: [partnerId], references: [id])

  @@unique([partnerId, companyId])
  @@index([partnerId])
  @@index([companyId])
}

model PartnerCommission {
  id          String    @id @default(cuid())
  partnerId   String
  montant     Int
  source      String?
  reference   String?
  status      String    @default("EN_ATTENTE")
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  partner     Partner   @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([status])
}
