generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PlanAbonnement {
  id               String    @id @default(cuid())
  nom              String
  description      String?
  prixMensuel      Int       @default(0)
  prixAnnuel       Int       @default(0)
  maxEmployes      Int       @default(5)
  maxUtilisateurs  Int       @default(2)
  maxClients       Int       @default(50)
  maxProduits      Int       @default(100)
  maxFacturesMois  Int       @default(50)
  modules          String    @default("facturation,clients,produits")
  support          String    @default("email")
  sauvegardeAuto   Boolean   @default(true)
  apiAccess        Boolean   @default(false)
  personnalisation Boolean   @default(false)
  multiSociete     Boolean   @default(false)
  rapportsAvances  Boolean   @default(false)
  actif            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  companies        Company[]
}

model Company {
  id                      String                 @id @default(cuid())
  nom                     String
  email                   String?
  telephone               String?
  adresse                 String?
  ville                   String?
  pays                    String                 @default("Guinée")
  codePays                String                 @default("GN")
  ninea                   String?
  logo                    String?
  devise                  String                 @default("GNF")
  symboleDevise           String                 @default("GNF")
  planId                  String?                @default("free")
  dateDebutAbonnement     DateTime?
  dateFinAbonnement       DateTime?
  configTauxCNSSEmploye   Float?
  configTauxCNSSEmployeur Float?
  configPlafondCNSS       Int?
  configTauxTVA           Float?                 @default(0.18)
  langue                  String                 @default("fr")
  fuseauHoraire           String                 @default("Africa/Conakry")
  formatDateTime          String                 @default("DD/MM/YYYY")
  notificationEmail       Boolean                @default(true)
  notificationSMS         Boolean                @default(false)
  actif                   Boolean                @default(true)
  dateEssaiFin            DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  activitesCRM            ActiviteCRM[]
  bonsLivraison           BonLivraison[]
  bulletins               BulletinPaie[]
  clients                 Client[]
  commandesClient         CommandeClient[]
  commandesFournisseur    CommandeFournisseur[]
  planAbonnement          PlanAbonnement?        @relation(fields: [planId], references: [id])
  conversionsDevise       ConversionDevise[]
  depenses                Depense[]
  devis                   Devis[]
  employes                Employe[]
  entrepots               Entrepot[]
  exercicesComptables     ExerciceComptable[]
  factures                Facture[]
  fournisseurs            Fournisseur[]
  historiqueAbonnements   HistoriqueAbonnement[]
  inventaires             Inventaire[]
  journauxComptables      JournalComptable[]
  lignesBilan             LigneBilan[]
  lignesCompteResultat    LigneCompteResultat[]
  opportunites            Opportunite[]
  paiementsAbonnement     PaiementAbonnement[]
  parametres              ParametreSociete[]
  pipelinesVente          PipelineVente[]
  produits                Produit[]
  prospects               Prospect[]
  soldesComptes           SoldeCompte[]
  tickets                 SupportTicket[]
  transfertsStock         TransfertStock[]
  users                   User[]
  modulesConfig           ModuleConfiguration[]

  @@index([pays])
  @@index([planId])
}

model ParametreSociete {
  id          String   @id @default(cuid())
  companyId   String
  cle         String
  valeur      String
  type        String   @default("string")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, cle])
  @@index([companyId])
}

model HistoriqueAbonnement {
  id                String    @id @default(cuid())
  companyId         String
  planId            String
  planNom           String
  dateDebut         DateTime
  dateFin           DateTime?
  prix              Int
  modePaiement      String?
  referencePaiement String?
  statut            String    @default("ACTIF")
  createdAt         DateTime  @default(now())
  company           Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model User {
  id                      String          @id @default(cuid())
  email                   String          @unique
  password                String
  nom                     String
  prenom                  String
  telephone               String?
  avatar                  String?
  role                    String          @default("COMPTABLE")
  companyId               String
  actif                   Boolean         @default(true)
  emailVerifie            Boolean         @default(false)
  dernierLogin            DateTime?
  preferences             String?
  twoFactorEnabled        Boolean         @default(false)
  twoFactorMethod         String?
  twoFactorSecret         String?
  twoFactorOTP            String?
  twoFactorOTPExpiry      DateTime?
  twoFactorRecoveryCodes  String?
  resetToken              String?
  resetTokenExpiry        DateTime?
  verificationToken       String?
  verificationTokenExpiry DateTime?
  loginAttempts           Int             @default(0)
  lockedUntil             DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  assignedTickets         SupportTicket[] @relation("AssignedTickets")
  company                 Company         @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
}

model Client {
  id           String           @id @default(cuid())
  nom          String
  email        String?
  telephone    String?
  adresse      String?
  ville        String?
  pays         String           @default("Guinée")
  type         String           @default("PARTICULIER")
  ninea        String?
  totalAchats  Int              @default(0)
  notes        String?
  companyId    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id])
  commandes    CommandeClient[]
  devis        Devis[]
  factures     Facture[]
  opportunites Opportunite[]
  prospects    Prospect[]

  @@index([companyId])
  @@index([email])
}

model Produit {
  id                        String                     @id @default(cuid())
  nom                       String
  description               String?
  reference                 String?
  prixUnitaire              Int
  unite                     String                     @default("Unité")
  stockActuel               Int                        @default(0)
  stockMin                  Int                        @default(0)
  stockMax                  Int?
  categorie                 String?
  tva                       Float?                     @default(0.18)
  actif                     Boolean                    @default(true)
  type                      String                     @default("PRODUIT")
  companyId                 String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  lignesBonLivraison        LigneBonLivraison[]
  lignesCommandeClient      LigneCommandeClient[]
  lignesCommandeFournisseur LigneCommandeFournisseur[]
  lignesDevis               LigneDevis[]
  lignesFacture             LigneFacture[]
  lignesInventaire          LigneInventaire[]
  lignesTransfert           LigneTransfert[]
  company                   Company                    @relation(fields: [companyId], references: [id])
  stocksEntrepot            StockEntrepot[]

  @@index([companyId])
  @@index([categorie])
}

model Facture {
  id           String         @id @default(cuid())
  numero       String
  clientId     String
  dateEmission DateTime       @default(now())
  dateEcheance DateTime
  montantHT    Int
  montantTVA   Int
  montantTTC   Int
  totalTtc     Int            @default(0)
  montantPaye  Int            @default(0)
  statut       String         @default("BROUILLON")
  modePaiement String?
  notes        String?
  conditions   String?
  companyId    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  company      Company        @relation(fields: [companyId], references: [id])
  client       Client         @relation(fields: [clientId], references: [id])
  lignes       LigneFacture[]
  paiements    Paiement[]

  @@unique([numero, companyId])
  @@index([companyId])
  @@index([statut])
  @@index([dateEmission])
}

model LigneFacture {
  id           String   @id @default(cuid())
  factureId    String
  produitId    String?
  description  String
  quantite     Int
  prixUnitaire Int
  tauxTVA      Float    @default(0.18)
  montantHT    Int
  montantTVA   Int
  montantTTC   Int
  produit      Produit? @relation(fields: [produitId], references: [id])
  facture      Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@index([factureId])
  @@index([produitId])
}

model Paiement {
  id                  String   @id @default(cuid())
  factureId           String
  montant             Int
  date                DateTime @default(now())
  mode                String
  reference           String?
  referenceMobile     String?
  orangeTransactionId String?
  mtnTransactionId    String?
  waveTransactionId   String?
  notes               String?
  createdAt           DateTime @default(now())
  facture             Facture  @relation(fields: [factureId], references: [id])

  @@index([factureId])
}

model Employe {
  id                    String         @id @default(cuid())
  matricule             String
  nom                   String
  prenom                String
  email                 String?
  telephone             String?
  adresse               String?
  dateNaissance         DateTime?
  lieuNaissance         String?
  nationalite           String?
  situationMatrimoniale String?
  nombreEnfants         Int            @default(0)
  dateEmbauche          DateTime
  dateDepart            DateTime?
  motifDepart           String?
  poste                 String
  departement           String?
  salaireBase           Int
  typeContrat           String         @default("CDI")
  dureeContratMois      Int?
  actif                 Boolean        @default(true)
  photo                 String?
  numeroCNSS            String?
  nombrePartsFiscales   Int            @default(1)
  companyId             String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  bulletins             BulletinPaie[]
  conges                Conge[]
  company               Company        @relation(fields: [companyId], references: [id])

  @@unique([matricule, companyId])
  @@index([companyId])
  @@index([departement])
}

model Conge {
  id              String    @id @default(cuid())
  employeId       String
  type            String
  dateDebut       DateTime
  dateFin         DateTime
  nombreJours     Int
  motif           String?
  statut          String    @default("EN_ATTENTE")
  approuvePar     String?
  dateApprobation DateTime?
  commentaire     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employe         Employe   @relation(fields: [employeId], references: [id])

  @@index([employeId])
  @@index([statut])
}

model BulletinPaie {
  id                    String    @id @default(cuid())
  employeId             String
  mois                  Int
  annee                 Int
  periodePaiement       String?
  salaireBase           Int
  heuresSupplementaires Int       @default(0)
  tauxHoraireSupp       Int       @default(0)
  montantHeuresSupp     Int       @default(0)
  primes                Int       @default(0)
  primesDetail          String?
  indemnites            Int       @default(0)
  indemnitesDetail      String?
  autresAvantages       Int       @default(0)
  brutTotal             Int
  baseCNSS              Int
  cnssEmploye           Int
  cnssEmployeur         Int
  baseImposable         Int
  ipr                   Int
  autresRetenues        Int       @default(0)
  acomptes              Int       @default(0)
  totalRetenues         Int
  netAPayer             Int
  netImposable          Int
  coutTotalEmployeur    Int
  taxesAdditionnelles   String?
  statut                String    @default("BROUILLON")
  datePaiement          DateTime?
  modePaiement          String?
  referencePaiement     String?
  companyId             String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  company               Company   @relation(fields: [companyId], references: [id])
  employe               Employe   @relation(fields: [employeId], references: [id])

  @@unique([employeId, mois, annee])
  @@index([companyId])
  @@index([statut])
}

model Depense {
  id            String   @id @default(cuid())
  description   String
  montant       Int
  categorie     String
  sousCategorie String?
  date          DateTime @default(now())
  modePaiement  String
  beneficiaire  String?
  notes         String?
  recuUrl       String?
  valide        Boolean  @default(false)
  validePar     String?
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([categorie])
  @@index([date])
}

model CategorieDepense {
  id          String   @id @default(cuid())
  nom         String
  description String?
  couleur     String?
  icone       String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([nom, companyId])
  @@index([companyId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  table     String
  recordId  String?
  userId    String?
  companyId String?
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  titre      String
  message    String
  type       String
  lu         Boolean  @default(false)
  actionUrl  String?
  actionType String?
  actionId   String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([lu])
}

model SmsLog {
  id        String   @id @default(cuid())
  telephone String
  message   String
  statut    String
  erreur    String?
  cout      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([telephone])
  @@index([createdAt])
}

model EmailLog {
  id           String   @id @default(cuid())
  destinataire String
  sujet        String
  contenu      String?
  statut       String
  erreur       String?
  templateId   String?
  createdAt    DateTime @default(now())

  @@index([destinataire])
  @@index([createdAt])
}

model TachePlanifiee {
  id             String    @id @default(cuid())
  nom            String
  description    String?
  type           String
  cronExpression String?
  prochaineExec  DateTime?
  derniereExec   DateTime?
  actif          Boolean   @default(true)
  configuration  String?
  derniereErreur String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type])
  @@index([prochaineExec])
}

model SupportTicket {
  id            String          @id @default(cuid())
  sujet         String
  description   String
  priorite      String          @default("NORMALE")
  statut        String          @default("OUVERT")
  categorie     String          @default("AUTRE")
  userId        String
  companyId     String
  assigneeId    String?
  piecesJointes String?
  satisfaction  Int?
  commentaire   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  resoluAt      DateTime?
  fermeAt       DateTime?
  assignee      User?           @relation("AssignedTickets", fields: [assigneeId], references: [id])
  company       Company         @relation(fields: [companyId], references: [id])
  reponses      TicketReponse[]

  @@index([userId])
  @@index([companyId])
  @@index([statut])
  @@index([priorite])
}

model TicketReponse {
  id            String        @id @default(cuid())
  ticketId      String
  auteurId      String
  auteurType    String
  message       String
  piecesJointes String?
  interne       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model PaiementAbonnement {
  id              String    @id @default(cuid())
  companyId       String
  montant         Int
  devise          String    @default("GNF")
  methode         String
  reference       String?
  numeroTelephone String?
  statut          String    @default("EN_ATTENTE")
  detailsReponse  String?
  planId          String
  planNom         String
  duree           String
  factureUrl      String?
  createdAt       DateTime  @default(now())
  traiteAt        DateTime?
  company         Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([statut])
  @@index([createdAt])
}

model Devis {
  id            String       @id @default(cuid())
  numero        String
  clientId      String
  dateEmission  DateTime     @default(now())
  dateValidite  DateTime
  montantHT     Int
  montantTVA    Int
  montantTTC    Int
  statut        String       @default("BROUILLON")
  conditions    String?
  notes         String?
  companyId     String
  factureId     String?
  opportuniteId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  opportunite   Opportunite? @relation(fields: [opportuniteId], references: [id])
  company       Company      @relation(fields: [companyId], references: [id])
  client        Client       @relation(fields: [clientId], references: [id])
  lignes        LigneDevis[]

  @@unique([numero, companyId])
  @@index([companyId])
  @@index([statut])
}

model LigneDevis {
  id           String   @id @default(cuid())
  devisId      String
  produitId    String?
  description  String
  quantite     Int
  prixUnitaire Int
  tauxTVA      Float    @default(0.18)
  montantHT    Int
  montantTVA   Int
  montantTTC   Int
  produit      Produit? @relation(fields: [produitId], references: [id])
  devis        Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OrangeMoneyAccount {
  id           String   @id @default(cuid())
  companyId    String
  apiKey       String
  apiSecret    String
  merchantCode String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

model OrangeMoneyTransaction {
  id            String    @id @default(cuid())
  companyId     String
  orderId       String    @unique
  orangeTxId    String?
  amount        Int
  currency      String    @default("GNF")
  customerPhone String
  customerName  String?
  type          String?   @default("PAYMENT") // PAYMENT, TRANSFER_P2P, QRCODE
  status        String    @default("PENDING")
  errorMessage  String?
  metadata      String?
  expiresAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([type])
}

model OrangeMoneyQRCode {
  id           String    @id
  companyId    String
  merchantCode String
  amount       Int
  currency     String    @default("GNF")
  description  String?
  status       String    @default("ACTIVE") // ACTIVE, USED, EXPIRED, CANCELLED
  usedBy       String?
  usedAt       DateTime?
  expiresAt    DateTime
  metadata     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([expiresAt])
}

model MtnMoneyAccount {
  id               String   @id @default(cuid())
  companyId        String
  subscriptionKey  String
  disbursementKey  String?
  accountNumber    String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
}

model MtnMoneyTransaction {
  id                    String    @id @default(cuid())
  companyId             String
  externalId            String    @unique
  reference             String?
  financialTransactionId String?
  amount                Int
  currency              String    @default("GNF")
  customerPhone         String
  customerName          String?
  type                  String    @default("COLLECTION")
  status                String    @default("PENDING")
  errorMessage          String?
  metadata              String?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model WaveAccount {
  id            String   @id @default(cuid())
  companyId     String
  apiKey        String
  apiSecret     String
  accountNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

model WaveTransaction {
  id            String    @id @default(cuid())
  companyId     String
  reference     String    @unique
  waveId        String?
  checkoutUrl   String?
  amount        Int
  currency      String    @default("GNF")
  customerPhone String
  customerName  String?
  type          String    @default("CHECKOUT")
  status        String    @default("PENDING")
  errorMessage  String?
  metadata      String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model NotificationSettings {
  id                   String   @id @default(cuid())
  companyId            String
  emailEnabled         Boolean  @default(true)
  smsEnabled           Boolean  @default(false)
  pushEnabled          Boolean  @default(true)
  invoiceCreated       Boolean  @default(true)
  invoicePaid          Boolean  @default(true)
  invoiceReminder      Boolean  @default(true)
  payrollReady         Boolean  @default(true)
  employeeHired        Boolean  @default(true)
  stockAlert           Boolean  @default(true)
  subscriptionExpiring Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
}

model Entrepot {
  id               String           @id @default(cuid())
  nom              String
  code             String?
  adresse          String?
  ville            String?
  telephone        String?
  responsable      String?
  actif            Boolean          @default(true)
  parDefaut        Boolean          @default(false)
  companyId        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company          @relation(fields: [companyId], references: [id])
  stocks           StockEntrepot[]
  transfertsDest   TransfertStock[] @relation("TransfertDest")
  transfertsSource TransfertStock[] @relation("TransfertSource")

  @@unique([nom, companyId])
  @@index([companyId])
}

model StockEntrepot {
  id          String   @id @default(cuid())
  entrepotId  String
  produitId   String
  quantite    Int      @default(0)
  emplacement String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  produit     Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  entrepot    Entrepot @relation(fields: [entrepotId], references: [id], onDelete: Cascade)

  @@unique([entrepotId, produitId])
  @@index([produitId])
  @@index([entrepotId])
}

model TransfertStock {
  id               String           @id @default(cuid())
  numero           String
  entrepotSourceId String
  entrepotDestId   String
  dateTransfert    DateTime         @default(now())
  statut           String           @default("EN_ATTENTE")
  notes            String?
  companyId        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lignes           LigneTransfert[]
  company          Company          @relation(fields: [companyId], references: [id])
  entrepotDest     Entrepot         @relation("TransfertDest", fields: [entrepotDestId], references: [id])
  entrepotSource   Entrepot         @relation("TransfertSource", fields: [entrepotSourceId], references: [id])

  @@unique([numero, companyId])
  @@index([companyId])
}

model LigneTransfert {
  id          String         @id @default(cuid())
  transfertId String
  produitId   String
  quantite    Int
  createdAt   DateTime       @default(now())
  produit     Produit        @relation(fields: [produitId], references: [id])
  transfert   TransfertStock @relation(fields: [transfertId], references: [id], onDelete: Cascade)

  @@index([transfertId])
  @@index([produitId])
}

model Fournisseur {
  id         String                @id @default(cuid())
  code       String?
  nom        String
  email      String?
  telephone  String?
  adresse    String?
  ville      String?
  pays       String                @default("Guinée")
  ninea      String?
  contactNom String?
  contactTel String?
  notes      String?
  actif      Boolean               @default(true)
  companyId  String
